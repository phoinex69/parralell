DJANGO_DEBUG=1
DJANGO_SECRET_KEY=change-this-for-real-deployment
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

REDIS_URL=redis://127.0.0.1:6379/0
CACHE_REDIS_URL=redis://127.0.0.1:6379/1

# Leave these empty to use SQLite for a quick local demo.
# Use PostgreSQL for real select_for_update concurrency testing.
POSTGRES_DB=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

MAX_CONCURRENT_REQUESTS=20
CAPACITY_WAIT_SECONDS=2
CELERY_WORKER_CONCURRENCY=4

# Docker Compose uses these service names internally:
# POSTGRES_HOST=db
# REDIS_URL=redis://redis:6379/0
# CACHE_REDIS_URL=redis://redis:6379/1
